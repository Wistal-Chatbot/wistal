ANTHROPIC_API_KEY="xxxxx"
# Model used for the chat orchestrator (text-to-SQL). Defaults to claude-sonnet-4-6.
ANTHROPIC_CHAT_MODEL="claude-sonnet-4-6"
# Optional. Admin API key for live monthly token-usage lookups. When empty, the
# monthly AI token limit is read but usage is treated as unavailable (does not block).
ANTHROPIC_ADMIN_KEY=""
DATABASE_URL="xxxxx"
# Optional fallback used by Drizzle tooling and compatible with the Blumpo setup.
POSTGRES_URL="xxxxx"
JWT_SECRET="xxxxx"
KV_REST_API_READ_ONLY_TOKEN="xxxxx"
KV_REST_API_TOKEN="xxxxx"
KV_REST_API_URL="xxxxxx"
KV_URL="xxxxx"
REDIS_URL="xxxxx"
RESEND_API_KEY="xxxxxx"
# Verified sender domain in Resend; change here to swap the OTP "from" address.
RESEND_FROM_EMAIL="no-reply@wistal-stal.pl"
BASE_URL="http://localhost:3000"
# Defaults to false: only @wistal.com.pl email addresses can log in.
# Set to "true" to allow OTP login for any email domain.
AUTH_ALLOW_NON_WISTAL_EMAILS="false"
# BizRaport API (external Polish company data — KRS, financials, KRZ, Monitor Sądowy).
# When both are set, the chat gets the get_company_info / search_company tools.
# Sent as HTTP Basic Auth; calls are billed per returned row.
BIZRAPORT_API_EMAIL="xxxx"
BIZRAPORT_API_PASSWORD="xxxxx"